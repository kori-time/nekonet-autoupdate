NEKONET_ROLE=A
NEKONET_COORDINATOR_NAME=falfa.kori.cat
NEKONET_COORDINATOR_IP=10.10.0.8
NEKONET_PEER_NAME=laika.kori.cat
NEKONET_PEER_IP=10.10.0.7
NEKONET_SERVER_A_IP=10.10.0.8
NEKONET_SERVER_B_IP=10.10.0.7

NEKONET_API_BIND=10.10.0.8
NEKONET_API_PORT=8088
NEKONET_API_TOKEN=CHANGE_ME
NEKONET_DISCORD_WEBHOOK=

NEKONET_SSH_USER=root
NEKONET_SSH_PORT=2222
NEKONET_SSH_KEY=/root/.ssh/nekonet-autoupdate

NEKONET_UPDATE_SPACING_SECONDS=300
NEKONET_REBOOT_SPACING_SECONDS=600
NEKONET_SERVER_RETURN_TIMEOUT_SECONDS=600

NEKONET_STORAGE_ORDER=mysql,postgresql,sqlite,json
NEKONET_MYSQL_DSN=mysql+asyncmy://user:password@10.10.0.50:3306/nekonet_autoupdate
NEKONET_POSTGRESQL_DSN=postgresql+asyncpg://user:password@10.10.0.50:5432/nekonet_autoupdate
NEKONET_SQLITE_PATH=/var/lib/nekonet-autoupdate/state.db
NEKONET_JSON_PATH=/var/lib/nekonet-autoupdate/status.json

NEKONET_MAX_AVG_RTT_MS=250
NEKONET_MAX_PACKET_LOSS_PERCENT=20
NEKONET_MAX_CLOCK_SKEW_SECONDS=5

NEKONET_FLEET_PATH=/etc/nekonet-autoupdate/fleet.json
NEKONET_STORAGE_RETRY_SECONDS=30
