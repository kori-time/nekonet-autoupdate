DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN"

SSH_USER="root"
SSH_PORT="2222"
SSH_KEY="/root/.ssh/nekonet-autoupdate"
FLEET_FILE="/etc/nekonet-autoupdate/fleet.conf"

# Server A example. On Server B, swap coordinator/peer and set role B.
COORDINATOR_ROLE="A"
COORDINATOR_NAME="falfa.kori.cat"
COORDINATOR_IP="10.10.0.8"

PEER_NAME="laika.kori.cat"
PEER_IP="10.10.0.7"

SERVER_A_NAME="falfa.kori.cat"
SERVER_A_IP="10.10.0.8"
SERVER_B_NAME="laika.kori.cat"
SERVER_B_IP="10.10.0.7"

UPDATE_SPACING_SECONDS="300"
REBOOT_SPACING_SECONDS="600"
SECONDARY_START_DELAY_SECONDS="900"
PEER_RESPONSE_TIMEOUT_SECONDS="45"
SERVER_RETURN_TIMEOUT_SECONDS="600"
