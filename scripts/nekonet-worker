#!/usr/bin/env bash
set -Eeuo pipefail
A="${1:-}"; shift || true
json(){ python3 - "$@" <<'PYWORK'
import json,sys
print(json.dumps(dict(x.split('=',1) for x in sys.argv[1:])))
import json,sys
print(json.dumps(dict(x.split('=',1) for x in sys.argv[1:])))
PYWORK
}
case "$A" in
 time) python3 -c 'import json,time;print(json.dumps({"epoch":int(time.time())}))';;
 update|update-local)
  export DEBIAN_FRONTEND=noninteractive NEEDRESTART_MODE=a
  apt-get -o DPkg::Lock::Timeout=900 update >/tmp/nekonet-apt.log 2>&1
  sim="$(apt-get -o DPkg::Lock::Timeout=900 --simulate dist-upgrade)"; count="$(awk '/^Inst /{c++} END{print c+0}' <<<"$sim")"; kernel=false; grep -Eq '^Inst (linux-image|linux-headers|linux-generic|linux-modules|linux-virtual)' <<<"$sim" && kernel=true
  if ((count>0));then apt-get -o DPkg::Lock::Timeout=900 -y dist-upgrade >>/tmp/nekonet-apt.log 2>&1; apt-get -o DPkg::Lock::Timeout=900 -y autoremove >>/tmp/nekonet-apt.log 2>&1; apt-get clean;fi
  reboot=false; [[ -f /var/run/reboot-required ]] && reboot=true; [[ "$kernel" == true ]] && reboot=true
  python3 -c 'import json,sys;print(json.dumps({"packages":int(sys.argv[1]),"kernel_updated":sys.argv[2]=="true","reboot_required":sys.argv[3]=="true"}))' "$count" "$kernel" "$reboot";;
 reboot|reboot-local) shutdown -r +1 'NekoNet AutoUpdate'; echo '{"scheduled":true}';;
 health) bad="$(systemctl --failed --no-legend 2>/dev/null | wc -l)"; python3 -c 'import json,sys;print(json.dumps({"healthy":int(sys.argv[1])==0,"failed_units":int(sys.argv[1])}))' "$bad";;
 cert-status) name="${1:?}"; test -r "/etc/letsencrypt/live/$name/fullchain.pem"; openssl x509 -in "/etc/letsencrypt/live/$name/fullchain.pem" -noout -serial -enddate | python3 -c 'import sys,json; print(json.dumps({"status":"present","details":sys.stdin.read()}))';;
 cert-create) name="${1:?}"; email="${2:?}"; webroot="${3:?}"; shift 3; args=(); for d in "$@";do args+=(-d "$d");done; certbot certonly --webroot -w "$webroot" --non-interactive --agree-tos --email "$email" --cert-name "$name" "${args[@]}"; echo '{"created":true}';;
 cert-export) name="${1:?}"; tar -C "/etc/letsencrypt/live/$name" -chf - cert.pem chain.pem fullchain.pem privkey.pem;;
 cert-install) name="${1:?}"; stage="/var/lib/nekonet-autoupdate/cert-stage/$name"; dest="/etc/nekonet-autoupdate/tls/$name"; test -r "$stage/fullchain.pem" -a -r "$stage/privkey.pem"; ch="$(openssl x509 -in "$stage/fullchain.pem" -pubkey -noout|openssl sha256)"; kh="$(openssl pkey -in "$stage/privkey.pem" -pubout|openssl sha256)"; [[ "$ch" == "$kh" ]]; install -d -m 750 "$dest"; install -m 640 "$stage"/*.pem "$dest"/; echo '{"installed":true}';;
 *) echo "unknown action" >&2; exit 2;;
esac
